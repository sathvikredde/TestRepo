						"dependsOn": [
							{
								"activity": "Set_startime",
								"dependencyConditions": [
									"Succeeded"
								]
							},
							{
								"activity": "Set_EndTime",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 3,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"dataset": {
								"referenceName": "ds_adls_new",
								"type": "DatasetReference",
