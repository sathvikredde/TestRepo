{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-dev-md-001"
		},
		"AzureBlobStorage1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'AzureBlobStorage1'"
		},
		"ls_adlsgen2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adlsgen2'"
		},
		"ls_gen2_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_gen2'"
		},
		"ls_adlsgen2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storagedevmd.dfs.core.windows.net/"
		},
		"ls_dummyJSON_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://dummyjson.com"
		},
		"ls_kv_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-dev-001-md.vault.azure.net/"
		},
		"ls_sftp_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "storagedevmd.blob.core.windows.net"
		},
		"ls_sftp_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "storagedevmd.sftpuser"
		},
		"ls_sqldb_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "harpdevserver.database.windows.net"
		},
		"ls_sqldb_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "devdb"
		},
		"ls_sqldb_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "harpadmin"
		},
		"TW2_properties_pipeline_parameters_p_startTime": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowStartTime"
		},
		"TW2_properties_pipeline_parameters_p_endTime": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowEndTime"
		},
		"tr_sathvik_properties_pipeline_parameters_p_windowStart": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowStartTime"
		},
		"tr_sathvik_properties_pipeline_parameters_p_windowEnd": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowEndTime"
		},
		"trigger1_properties_pipeline_parameters_p_startTime": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowStartTime"
		},
		"trigger1_properties_pipeline_parameters_p_endTime": {
			"type": "string",
			"defaultValue": "@trigger().outputs.windowEndTime"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-dev-md-001_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureBlobStorage1_connectionString": {
						"value": "[parameters('AzureBlobStorage1_connectionString')]"
					},
					"ls_adlsgen2_accountKey": {
						"value": "[parameters('ls_adlsgen2_accountKey')]"
					},
					"ls_gen2_connectionString": {
						"value": "[parameters('ls_gen2_connectionString')]"
					},
					"ls_adlsgen2_properties_typeProperties_url": {
						"value": "[parameters('ls_adlsgen2_properties_typeProperties_url')]"
					},
					"ls_dummyJSON_properties_typeProperties_url": {
						"value": "[parameters('ls_dummyJSON_properties_typeProperties_url')]"
					},
					"ls_kv_properties_typeProperties_baseUrl": {
						"value": "[parameters('ls_kv_properties_typeProperties_baseUrl')]"
					},
					"ls_sftp_properties_typeProperties_host": {
						"value": "[parameters('ls_sftp_properties_typeProperties_host')]"
					},
					"ls_sftp_properties_typeProperties_userName": {
						"value": "[parameters('ls_sftp_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-dev-md-001_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_sqldb_properties_typeProperties_server": {
						"value": "[parameters('ls_sqldb_properties_typeProperties_server')]"
					},
					"ls_sqldb_properties_typeProperties_database": {
						"value": "[parameters('ls_sqldb_properties_typeProperties_database')]"
					},
					"ls_sqldb_properties_typeProperties_userName": {
						"value": "[parameters('ls_sqldb_properties_typeProperties_userName')]"
					},
					"TW2_properties_pipeline_parameters_p_startTime": {
						"value": "[parameters('TW2_properties_pipeline_parameters_p_startTime')]"
					},
					"TW2_properties_pipeline_parameters_p_endTime": {
						"value": "[parameters('TW2_properties_pipeline_parameters_p_endTime')]"
					},
					"tr_sathvik_properties_pipeline_parameters_p_windowStart": {
						"value": "[parameters('tr_sathvik_properties_pipeline_parameters_p_windowStart')]"
					},
					"tr_sathvik_properties_pipeline_parameters_p_windowEnd": {
						"value": "[parameters('tr_sathvik_properties_pipeline_parameters_p_windowEnd')]"
					},
					"trigger1_properties_pipeline_parameters_p_startTime": {
						"value": "[parameters('trigger1_properties_pipeline_parameters_p_startTime')]"
					},
					"trigger1_properties_pipeline_parameters_p_endTime": {
						"value": "[parameters('trigger1_properties_pipeline_parameters_p_endTime')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-dev-md-001_ArmTemplate_0')]"
			]
		}
	]
}